---
import { client } from "../lib/tina";
import HomePage from "../components/HomePage";

const tinaProps = await client.queries.homepage({ relativePath: "index.mdx" });
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{tinaProps.data.homepage.heroText}</title>
    <style>
      body { font-family: sans-serif; max-width: 720px; margin: 60px auto; padding: 0 24px; color: #1a1a1a; }
      .edit-hint { margin-top: 3rem; font-size: 0.85rem; color: #888; }
      .edit-hint a { color: #888; }
    </style>
  </head>
  <body>
    <HomePage
      query={tinaProps.query}
      variables={tinaProps.variables}
      data={tinaProps.data}
      client:only="react"
    />
    <p class="edit-hint">
      <a href="/admin/#/~">Open visual editor →</a>
    </p>
  </body>
</html>
